{
  "name": "qualyx-monorepo",
  "version": "0.3.0",
  "private": true,
  "type": "module",
  "workspaces": [
    "packages/*",
    "apps/*"
  ],
  "scripts": {
    "build": "npm run build --workspaces --if-present",
    "build:core": "npm run build -w packages/core",
    "build:cli": "npm run build -w packages/cli",
    "build:worker": "npm run build -w packages/worker",
    "dev": "tsx packages/cli/src/index.ts",
    "start": "node packages/cli/dist/index.js",
    "test": "vitest",
    "dev:web": "npm run dev -w web",
    "typecheck": "npm run typecheck --workspaces --if-present",
    "lint": "eslint packages/*/src/ apps/*/src/"
  },
  "devDependencies": {
    "tsx": "^4.19.2",
    "typescript": "^5.7.3",
    "vitest": "^2.1.8"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
